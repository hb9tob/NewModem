{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "nbfm-modem-gui",
  "version": "0.1.0",
  "identifier": "org.hb9tob.nbfm-modem-gui",
  "build": {
    "frontendDist": "../src",
    "beforeBuildCommand": "cargo build --release -p modem-cli"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "NBFM Modem RX",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "dragDropEnabled": true,
        "maximized": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "appimage", "nsis"],
    "externalBin": ["binaries/nbfm-modem"],
    "category": "Utility",
    "shortDescription": "NBFM modem audio receiver",
    "longDescription": "GUI receiver for NBFM audio modem (amateur radio image transmission).",
    "publisher": "HB9TOB",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.ico"
    ],
    "linux": {
      "deb": {
        "depends": ["libwebkit2gtk-4.1-0", "libgtk-3-0", "libasound2"]
      }
    }
  }
}
