{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default permissions for main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-set-fullscreen",
    "opener:default",
    "opener:allow-reveal-item-in-dir",
    {
      "identifier": "core:image:allow-new",
      "allow": [{ "path": "**" }]
    }
  ]
}
