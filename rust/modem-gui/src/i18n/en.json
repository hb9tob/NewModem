  "settings.rx_deemphasis": "PM de-emphasis −6 dB/oct (legacy FM radio)",
  "settings.rx_deemphasis_hint": "Falling slope −6 dB/oct above 300 Hz (~−10 dB at 1 kHz, ~−19 dB at 2.7 kHz). Exact mirror of the TX pre-emphasis below: together they emulate the ±6 dB/oct intrinsic to a PM radio. Raw WAV capture and level meter are untouched — only the modem demodulator sees the filtered signal. Enable only if the radio is true FM (no native ±6 dB/oct PM).",
  "settings.rx_power_mode": "Power Mode",
  "settings.rx_power_mode_hint_html": "RX 0.9.x algorithm — full ±80 ppm drift sweep per window (coarse 20 ppm + fine ±10 ppm). Proven robust decode. Flat 6 s preamble-absence timeout for all profiles (strict 0.9.2rc5). Recommended on a modern PC, uncheck on Pi or old PC where the worker may fall behind real time. <em>Disabled by default on Raspberry Pi.</em>",
  "settings.legend_tx_device": "Transmit device (TX)",
  "settings.tx_preemphasis": "PM pre-emphasis +6 dB/oct (legacy FM radio)",
  "settings.tx_preemphasis_hint": "Rising slope +6 dB/oct above 300 Hz (~+10 dB at 1 kHz, ~+19 dB at 2.7 kHz). Emulates the ±6 dB/oct pre-emphasis intrinsic to a PM radio. The signal is re-normalised after filtering so the TX output does not clip. Enable only if the radio is true FM (no native ±6 dB/oct PM) — always paired with RX de-emphasis on the receiver side.",
  "settings.tx_save_wav": "Save the transmitted WAV in tx_history/",
  "settings.tx_save_wav_hint": "Writes the synthesised audio (mono 48 kHz int16, post pre-emphasis and attenuation) next to the archived source file. Disabled by default.",
